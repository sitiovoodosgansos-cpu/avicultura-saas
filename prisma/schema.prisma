generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
  SUPER_ADMIN
}

enum TenantStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELED
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum BirdSex {
  FEMALE
  MALE
  UNKNOWN
}

enum BirdStatus {
  ACTIVE
  SICK
  DEAD
  BROODY
}

enum IncubatorStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum BatchStatus {
  ACTIVE
  HATCHED
  FAILED
  CANCELED
}

enum InfirmaryStatus {
  ACTIVE
  INACTIVE
}

enum InfirmaryCaseStatus {
  TREATING
  CURED
  DEAD
  TRANSFERRED
}

enum QuarantineCaseStatus {
  ACTIVE
  COMPLETED
  CANCELED
}

enum ReportType {
  GENERAL
  FLOCK
  EGG
  INCUBATOR
  HEALTH
  FINANCIAL
}

enum EggTrayStatus {
  ACTIVE
  EXHAUSTED
  ARCHIVED
}

enum EggTraySource {
  COLLECTION
  EXTERNAL
}

enum ListingStatus {
  AVAILABLE
  SOLD_OUT
  REMOVED
}

enum PaymentMethod {
  PIX
  CARD
  CASH
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  name         String
  role         UserRole       @default(MEMBER)
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  memberships  TenantMember[]
  auditLogs    AuditLog[]
  reports      Report[]
}

model Tenant {
  id                   String                        @id @default(cuid())
  name                 String
  slug                 String                        @unique
  status               TenantStatus                  @default(TRIAL)
  trialStartsAt        DateTime                      @default(now())
  trialEndsAt          DateTime
  createdAt            DateTime                      @default(now())
  updatedAt            DateTime                      @updatedAt
  members              TenantMember[]
  farms                Farm[]
  subscriptions        Subscription[]
  paymentEvents        PaymentEvent[]
  species              Species[]
  breeds               Breed[]
  varieties            Variety[]
  flockGroups          FlockGroup[]
  birds                Bird[]
  birdHistories        BirdStatusHistory[]
  eggCollections       EggCollection[]
  incubators           Incubator[]
  batches              IncubatorBatch[]
  batchEvents          IncubatorBatchEvent[]
  batchSources         IncubatorBatchSource[]
  infirmaries          Infirmary[]
  infirmaryCases       InfirmaryCase[]
  infirmaryCaseEvents  InfirmaryCaseEvent[]
  quarantineTemplates  QuarantineChecklistTemplate[]
  quarantineCases      QuarantineCase[]
  quarantineTreatments QuarantineTreatment[]
  entries              FinancialEntry[]
  expenses             FinancialExpense[]
  employeeAccounts     EmployeeAccount[]
  employeeSessions     EmployeeSession[]
  workerLinks          WorkerAccessLink[]
  reports              Report[]
  auditLogs            AuditLog[]
  eggTrays             EggTray[]
  eggTrayEntries       EggTrayEntry[]
  eggSales             EggSale[]
  eggSaleItems         EggSaleItem[]
  priceTiers           PriceTier[]
  vitrineListings      VitrineListing[]
  vitrineSales         VitrineSale[]
}

model TenantMember {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  role      UserRole @default(OWNER)
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
}

model Farm {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  location  String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                 String             @id @default(cuid())
  tenantId           String
  provider           String             @default("stripe")
  providerCustomerId String?
  providerSubId      String?
  status             SubscriptionStatus @default(TRIALING)
  planCode           String             @default("starter")
  trialEndsAt        DateTime?
  currentPeriodEnd   DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  tenant             Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model PaymentEvent {
  id              String    @id @default(cuid())
  tenantId        String
  providerEventId String    @unique
  type            String
  payload         Json
  processedAt     DateTime?
  createdAt       DateTime  @default(now())
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Species {
  id        String       @id @default(cuid())
  tenantId  String
  name      String
  createdAt DateTime     @default(now())
  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  breeds    Breed[]
  groups    FlockGroup[]
}

model Breed {
  id        String       @id @default(cuid())
  tenantId  String
  speciesId String
  name      String
  createdAt DateTime     @default(now())
  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  species   Species      @relation(fields: [speciesId], references: [id], onDelete: Cascade)
  varieties Variety[]
  groups    FlockGroup[]
}

model Variety {
  id        String       @id @default(cuid())
  tenantId  String
  breedId   String
  name      String
  createdAt DateTime     @default(now())
  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  breed     Breed        @relation(fields: [breedId], references: [id], onDelete: Cascade)
  groups    FlockGroup[]
}

model FlockGroup {
  id                      String           @id @default(cuid())
  tenantId                String
  speciesId               String
  breedId                 String
  varietyId               String?
  title                   String
  bayNumber               Int              @default(1)
  matrixCount             Int              @default(0)
  reproducerCount         Int              @default(0)
  expectedLayCapacity     Float?
  purchaseInvestmentTotal Decimal?         @db.Decimal(12, 2)
  purchaseDate            DateTime?
  notes                   String?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  tenant                  Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  species                 Species          @relation(fields: [speciesId], references: [id], onDelete: Restrict)
  breed                   Breed            @relation(fields: [breedId], references: [id], onDelete: Restrict)
  variety                 Variety?         @relation(fields: [varietyId], references: [id], onDelete: SetNull)
  birds                   Bird[]
  eggCollections          EggCollection[]
  batches                 IncubatorBatch[]
  trays                   EggTray[]
  priceTiers              PriceTier[]
  vitrineListings         VitrineListing[]
}

model Bird {
  id              String              @id @default(cuid())
  tenantId        String
  flockGroupId    String
  bayNumber       Int?
  ringNumber      String
  nickname        String?
  sex             BirdSex             @default(UNKNOWN)
  acquisitionDate DateTime?
  purchaseValue   Decimal?            @db.Decimal(12, 2)
  origin          String?
  status          BirdStatus          @default(ACTIVE)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  flockGroup      FlockGroup          @relation(fields: [flockGroupId], references: [id], onDelete: Cascade)
  statusHistory   BirdStatusHistory[]
  infirmaryCases  InfirmaryCase[]
  quarantineCases QuarantineCase[]
  vitrineListing  VitrineListing?

  @@unique([tenantId, ringNumber])
}

model BirdStatusHistory {
  id         String      @id @default(cuid())
  tenantId   String
  birdId     String
  fromStatus BirdStatus?
  toStatus   BirdStatus
  reason     String?
  createdAt  DateTime    @default(now())
  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bird       Bird        @relation(fields: [birdId], references: [id], onDelete: Cascade)
}

model EggCollection {
  id           String        @id @default(cuid())
  tenantId     String
  flockGroupId String
  date         DateTime
  totalEggs    Int
  goodEggs     Int
  crackedEggs  Int
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  flockGroup   FlockGroup    @relation(fields: [flockGroupId], references: [id], onDelete: Cascade)
  trayEntry    EggTrayEntry?
}

model Incubator {
  id          String           @id @default(cuid())
  tenantId    String
  name        String
  description String?
  status      IncubatorStatus  @default(ACTIVE)
  notes       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  batches     IncubatorBatch[]
}

model IncubatorBatch {
  id                String                 @id @default(cuid())
  tenantId          String
  incubatorId       String
  flockGroupId      String
  entryDate         DateTime
  eggsSet           Int
  expectedHatchDate DateTime?
  status            BatchStatus            @default(ACTIVE)
  notes             String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  tenant            Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  incubator         Incubator              @relation(fields: [incubatorId], references: [id], onDelete: Cascade)
  flockGroup        FlockGroup             @relation(fields: [flockGroupId], references: [id], onDelete: Restrict)
  events            IncubatorBatchEvent[]
  sources           IncubatorBatchSource[]
  vitrineListings   VitrineListing[]
}

model IncubatorBatchEvent {
  id        String         @id @default(cuid())
  tenantId  String
  batchId   String
  type      String
  quantity  Int            @default(0)
  eventDate DateTime
  notes     String?
  createdAt DateTime       @default(now())
  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  batch     IncubatorBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
}

model IncubatorBatchSource {
  id             String         @id @default(cuid())
  tenantId       String
  batchId        String
  trayEntryId    String?
  collectionDate DateTime
  quantity       Int
  createdAt      DateTime       @default(now())
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  batch          IncubatorBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([tenantId, batchId])
}

model Infirmary {
  id              String           @id @default(cuid())
  tenantId        String
  name            String
  status          InfirmaryStatus  @default(ACTIVE)
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cases           InfirmaryCase[]
  quarantineCases QuarantineCase[]
}

model InfirmaryCase {
  id          String               @id @default(cuid())
  tenantId    String
  birdId      String
  infirmaryId String
  openedAt    DateTime
  diagnosis   String?
  symptoms    String?
  medication  String?
  dosage      String?
  responsible String?
  status      InfirmaryCaseStatus  @default(TREATING)
  notes       String?
  closedAt    DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  tenant      Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bird        Bird                 @relation(fields: [birdId], references: [id], onDelete: Restrict)
  infirmary   Infirmary            @relation(fields: [infirmaryId], references: [id], onDelete: Restrict)
  events      InfirmaryCaseEvent[]
}

model InfirmaryCaseEvent {
  id              String        @id @default(cuid())
  tenantId        String
  caseId          String
  type            String
  notes           String?
  fromInfirmaryId String?
  toInfirmaryId   String?
  createdAt       DateTime      @default(now())
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  case            InfirmaryCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
}

model QuarantineChecklistTemplate {
  id         String                @id @default(cuid())
  tenantId   String
  name       String
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  tenant     Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  treatments QuarantineTreatment[]

  @@unique([tenantId, name])
}

model QuarantineCase {
  id               String                @id @default(cuid())
  tenantId         String
  birdId           String
  infirmaryId      String
  entryDate        DateTime
  expectedExitDate DateTime
  notes            String?
  status           QuarantineCaseStatus  @default(ACTIVE)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  tenant           Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bird             Bird                  @relation(fields: [birdId], references: [id], onDelete: Restrict)
  infirmary        Infirmary             @relation(fields: [infirmaryId], references: [id], onDelete: Restrict)
  treatments       QuarantineTreatment[]
}

model QuarantineTreatment {
  id               String                       @id @default(cuid())
  tenantId         String
  quarantineCaseId String
  templateId       String?
  label            String
  startDate        DateTime
  notes            String?
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt
  tenant           Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  quarantineCase   QuarantineCase               @relation(fields: [quarantineCaseId], references: [id], onDelete: Cascade)
  template         QuarantineChecklistTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
}

model FinancialEntry {
  id            String         @id @default(cuid())
  tenantId      String
  date          DateTime
  category      String
  item          String
  amount        Decimal        @db.Decimal(12, 2)
  description   String?
  customer      String?
  notes         String?
  paymentMethod PaymentMethod?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  eggSale       EggSale?
  vitrineSale   VitrineSale?
}

model EggTray {
  id           String         @id @default(cuid())
  tenantId     String
  flockGroupId String?
  speciesLabel String
  breedLabel   String
  varietyLabel String?
  expiryDays   Int            @default(10)
  status       EggTrayStatus  @default(ACTIVE)
  notes        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  flockGroup   FlockGroup?    @relation(fields: [flockGroupId], references: [id], onDelete: SetNull)
  entries      EggTrayEntry[]

  @@index([tenantId, status])
}

model EggTrayEntry {
  id               String         @id @default(cuid())
  tenantId         String
  trayId           String
  eggCollectionId  String?        @unique
  source           EggTraySource  @default(COLLECTION)
  entryDate        DateTime
  initialCount     Int
  soldCount        Int            @default(0)
  discardedCount   Int            @default(0)
  transferredCount Int            @default(0)
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tray             EggTray        @relation(fields: [trayId], references: [id], onDelete: Cascade)
  eggCollection    EggCollection? @relation(fields: [eggCollectionId], references: [id], onDelete: SetNull)
  saleItems        EggSaleItem[]

  @@index([tenantId, trayId, entryDate])
}

model EggSale {
  id               String          @id @default(cuid())
  tenantId         String
  customer         String?
  totalAmount      Decimal         @db.Decimal(12, 2)
  soldAt           DateTime
  financialEntryId String?         @unique
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  tenant           Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  financialEntry   FinancialEntry? @relation(fields: [financialEntryId], references: [id], onDelete: SetNull)
  items            EggSaleItem[]

  @@index([tenantId, soldAt])
}

model EggSaleItem {
  id          String       @id @default(cuid())
  tenantId    String
  saleId      String
  trayEntryId String
  quantity    Int
  unitPrice   Decimal      @db.Decimal(10, 2)
  subtotal    Decimal      @db.Decimal(12, 2)
  createdAt   DateTime     @default(now())
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sale        EggSale      @relation(fields: [saleId], references: [id], onDelete: Cascade)
  trayEntry   EggTrayEntry @relation(fields: [trayEntryId], references: [id], onDelete: Restrict)
}

model FinancialExpense {
  id          String   @id @default(cuid())
  tenantId    String
  date        DateTime
  category    String
  item        String
  amount      Decimal  @db.Decimal(12, 2)
  description String?
  supplier    String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Report {
  id          String     @id @default(cuid())
  tenantId    String
  generatedBy String
  type        ReportType
  periodStart DateTime
  periodEnd   DateTime
  fileUrl     String?
  metadata    Json?
  createdAt   DateTime   @default(now())
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User       @relation(fields: [generatedBy], references: [id], onDelete: Restrict)
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String?
  action    String
  entity    String
  entityId  String
  before    Json?
  after     Json?
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model WorkerAccessLink {
  id              String   @id @default(cuid())
  tenantId        String
  label           String
  token           String   @unique
  isActive        Boolean  @default(true)
  allowPlantel    Boolean  @default(true)
  allowEggs       Boolean  @default(true)
  allowIncubators Boolean  @default(true)
  allowHealth     Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model EmployeeAccount {
  id              String            @id @default(cuid())
  tenantId        String
  name            String
  email           String
  passwordHash    String
  isActive        Boolean           @default(true)
  allowPlantel    Boolean           @default(true)
  allowEggs       Boolean           @default(true)
  allowIncubators Boolean           @default(true)
  allowHealth     Boolean           @default(true)
  lastLoginAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions        EmployeeSession[]

  @@unique([tenantId, email])
}

model EmployeeSession {
  id         String          @id @default(cuid())
  tenantId   String
  employeeId String
  token      String          @unique
  expiresAt  DateTime
  createdAt  DateTime        @default(now())
  tenant     Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee   EmployeeAccount @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model PriceTier {
  id           String   @id @default(cuid())
  tenantId     String
  flockGroupId String
  ageInMonths  Int
  price        Decimal  @db.Decimal(10, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  flockGroup FlockGroup @relation(fields: [flockGroupId], references: [id], onDelete: Cascade)

  @@unique([tenantId, flockGroupId, ageInMonths])
  @@index([tenantId, flockGroupId])
}

model VitrineListing {
  id                String        @id @default(cuid())
  tenantId          String
  flockGroupId      String
  title             String?
  birthDate         DateTime
  initialQuantity   Int
  availableQuantity Int
  priceOverride     Decimal?      @db.Decimal(10, 2)
  description       String?
  status            ListingStatus @default(AVAILABLE)

  sourceIncubatorBatchId String?
  sourceBirdId           String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  flockGroup FlockGroup @relation(fields: [flockGroupId], references: [id], onDelete: Restrict)

  sourceIncubatorBatch IncubatorBatch? @relation(fields: [sourceIncubatorBatchId], references: [id], onDelete: SetNull)
  sourceBird           Bird?           @relation(fields: [sourceBirdId], references: [id], onDelete: SetNull)

  photos VitrineListingPhoto[]
  sales  VitrineSale[]

  @@index([tenantId, status])
  @@index([tenantId, flockGroupId])
}

model VitrineListingPhoto {
  id        String   @id @default(cuid())
  listingId String
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  listing VitrineListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, order])
}

model VitrineSale {
  id               String        @id @default(cuid())
  tenantId         String
  listingId        String
  quantitySold     Int
  unitPrice        Decimal       @db.Decimal(10, 2)
  totalPrice       Decimal       @db.Decimal(10, 2)
  paymentMethod    PaymentMethod
  customer         String?
  notes            String?
  soldAt           DateTime      @default(now())
  financialEntryId String?       @unique

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  listing        VitrineListing  @relation(fields: [listingId], references: [id], onDelete: Restrict)
  financialEntry FinancialEntry? @relation(fields: [financialEntryId], references: [id], onDelete: SetNull)

  @@index([tenantId, listingId])
  @@index([tenantId, soldAt])
}
