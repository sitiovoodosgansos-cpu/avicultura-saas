generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
  SUPER_ADMIN
}

enum TenantStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELED
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum BirdSex {
  FEMALE
  MALE
  UNKNOWN
}

enum BirdStatus {
  ACTIVE
  SICK
  DEAD
  BROODY
  SOLD
}

enum IncubatorStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum BatchStatus {
  ACTIVE
  HATCHED
  FAILED
  CANCELED
}

enum InfirmaryStatus {
  ACTIVE
  INACTIVE
}

enum InfirmaryCaseStatus {
  TREATING
  CURED
  DEAD
  TRANSFERRED
}

enum QuarantineCaseStatus {
  ACTIVE
  COMPLETED
  CANCELED
}

enum ReportType {
  GENERAL
  FLOCK
  EGG
  INCUBATOR
  HEALTH
  FINANCIAL
}

enum EggTrayStatus {
  ACTIVE
  EXHAUSTED
  ARCHIVED
}

enum EggTraySource {
  COLLECTION
  EXTERNAL
}

enum ListingStatus {
  AVAILABLE
  SOLD_OUT
  REMOVED
}

enum PaymentMethod {
  PIX
  CARD
  CASH
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  name         String
  role         UserRole       @default(MEMBER)
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  memberships  TenantMember[]
  auditLogs    AuditLog[]
  reports      Report[]
}

model Tenant {
  id                   String                        @id @default(cuid())
  name                 String
  slug                 String                        @unique
  status               TenantStatus                  @default(TRIAL)
  trialStartsAt        DateTime                      @default(now())
  trialEndsAt          DateTime
  cnpj                 String?
  legalName            String?
  email                String?
  phone                String?
  whatsapp             String?
  addressLine          String?
  city                 String?
  stateUf              String?
  zipCode              String?
  logoUrl              String?
  receiptNotes         String?
  createdAt            DateTime                      @default(now())
  updatedAt            DateTime                      @updatedAt
  members              TenantMember[]
  farms                Farm[]
  subscriptions        Subscription[]
  paymentEvents        PaymentEvent[]
  species              Species[]
  breeds               Breed[]
  varieties            Variety[]
  flockGroups          FlockGroup[]
  birds                Bird[]
  birdHistories        BirdStatusHistory[]
  eggCollections       EggCollection[]
  incubators           Incubator[]
  batches              IncubatorBatch[]
  batchEvents          IncubatorBatchEvent[]
  batchSources         IncubatorBatchSource[]
  infirmaries          Infirmary[]
  infirmaryCases       InfirmaryCase[]
  infirmaryCaseEvents  InfirmaryCaseEvent[]
  quarantineTemplates  QuarantineChecklistTemplate[]
  quarantineCases      QuarantineCase[]
  quarantineTreatments QuarantineTreatment[]
  infirmaryCaseTreatments InfirmaryCaseTreatment[]
  entries              FinancialEntry[]
  expenses             FinancialExpense[]
  employeeAccounts     EmployeeAccount[]
  employeeSessions     EmployeeSession[]
  workerLinks          WorkerAccessLink[]
  reports              Report[]
  auditLogs            AuditLog[]
  eggTrays             EggTray[]
  eggTrayEntries       EggTrayEntry[]
  eggSales             EggSale[]
  eggSaleItems         EggSaleItem[]
  priceTiers           PriceTier[]
  vitrineListings      VitrineListing[]
  vitrineSales         VitrineSale[]
  vitrineDeaths        VitrineDeathRecord[]
  diseases             Disease[]
  medications          Medication[]
  vaccines             Vaccine[]
  deathReasons         DeathReason[]
  birdVaccinations     BirdVaccination[]
  leads                Lead[]
  leadHistory          LeadHistory[]
}

model TenantMember {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  role      UserRole @default(OWNER)
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
}

model Farm {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  location  String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                 String             @id @default(cuid())
  tenantId           String
  provider           String             @default("stripe")
  providerCustomerId String?
  providerSubId      String?
  status             SubscriptionStatus @default(TRIALING)
  planCode           String             @default("starter")
  trialEndsAt        DateTime?
  currentPeriodEnd   DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  tenant             Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model PaymentEvent {
  id              String    @id @default(cuid())
  tenantId        String
  providerEventId String    @unique
  type            String
  payload         Json
  processedAt     DateTime?
  createdAt       DateTime  @default(now())
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Species {
  id        String       @id @default(cuid())
  tenantId  String
  name      String
  createdAt DateTime     @default(now())
  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  breeds    Breed[]
  groups    FlockGroup[]
}

model Breed {
  id        String       @id @default(cuid())
  tenantId  String
  speciesId String
  name      String
  createdAt DateTime     @default(now())
  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  species   Species      @relation(fields: [speciesId], references: [id], onDelete: Cascade)
  varieties Variety[]
  groups    FlockGroup[]
}

model Variety {
  id        String       @id @default(cuid())
  tenantId  String
  breedId   String
  name      String
  createdAt DateTime     @default(now())
  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  breed     Breed        @relation(fields: [breedId], references: [id], onDelete: Cascade)
  groups    FlockGroup[]
}

model FlockGroup {
  id                      String           @id @default(cuid())
  tenantId                String
  speciesId               String
  breedId                 String
  varietyId               String?
  title                   String
  bayNumber               Int              @default(1)
  matrixCount             Int              @default(0)
  reproducerCount         Int              @default(0)
  expectedLayCapacity     Float?
  purchaseInvestmentTotal Decimal?         @db.Decimal(12, 2)
  purchaseDate            DateTime?
  notes                   String?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  tenant                  Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  species                 Species          @relation(fields: [speciesId], references: [id], onDelete: Restrict)
  breed                   Breed            @relation(fields: [breedId], references: [id], onDelete: Restrict)
  variety                 Variety?         @relation(fields: [varietyId], references: [id], onDelete: SetNull)
  birds                   Bird[]
  eggCollections          EggCollection[]
  batches                 IncubatorBatch[]
  trays                   EggTray[]
  priceTiers              PriceTier[]
  vitrineListings         VitrineListing[]
}

model Bird {
  id              String              @id @default(cuid())
  tenantId        String
  flockGroupId    String
  bayNumber       Int?
  ringNumber      String
  nickname        String?
  sex             BirdSex             @default(UNKNOWN)
  acquisitionDate DateTime?
  purchaseValue   Decimal?            @db.Decimal(12, 2)
  origin          String?
  status          BirdStatus          @default(ACTIVE)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  flockGroup      FlockGroup          @relation(fields: [flockGroupId], references: [id], onDelete: Cascade)
  statusHistory   BirdStatusHistory[]
  infirmaryCases  InfirmaryCase[]
  quarantineCases QuarantineCase[]
  vitrineListing  VitrineListing?
  vaccinations    BirdVaccination[]

  @@unique([tenantId, ringNumber])
}

model BirdStatusHistory {
  id         String      @id @default(cuid())
  tenantId   String
  birdId     String
  fromStatus BirdStatus?
  toStatus   BirdStatus
  reason     String?
  createdAt  DateTime    @default(now())
  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bird       Bird        @relation(fields: [birdId], references: [id], onDelete: Cascade)
}

model EggCollection {
  id           String        @id @default(cuid())
  tenantId     String
  flockGroupId String
  date         DateTime
  totalEggs    Int
  goodEggs     Int
  crackedEggs  Int
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  flockGroup   FlockGroup    @relation(fields: [flockGroupId], references: [id], onDelete: Cascade)
  trayEntry    EggTrayEntry?
}

model Incubator {
  id          String           @id @default(cuid())
  tenantId    String
  name        String
  description String?
  status      IncubatorStatus  @default(ACTIVE)
  notes       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  batches     IncubatorBatch[]
}

model IncubatorBatch {
  id                String                 @id @default(cuid())
  tenantId          String
  incubatorId       String
  flockGroupId      String
  entryDate         DateTime
  eggsSet           Int
  expectedHatchDate DateTime?
  status            BatchStatus            @default(ACTIVE)
  notes             String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  tenant            Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  incubator         Incubator              @relation(fields: [incubatorId], references: [id], onDelete: Cascade)
  flockGroup        FlockGroup             @relation(fields: [flockGroupId], references: [id], onDelete: Restrict)
  events            IncubatorBatchEvent[]
  sources           IncubatorBatchSource[]
  vitrineListings   VitrineListing[]
}

model IncubatorBatchEvent {
  id        String         @id @default(cuid())
  tenantId  String
  batchId   String
  type      String
  quantity  Int            @default(0)
  eventDate DateTime
  notes     String?
  createdAt DateTime       @default(now())
  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  batch     IncubatorBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
}

model IncubatorBatchSource {
  id             String         @id @default(cuid())
  tenantId       String
  batchId        String
  trayEntryId    String?
  collectionDate DateTime
  quantity       Int
  createdAt      DateTime       @default(now())
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  batch          IncubatorBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([tenantId, batchId])
}

model Infirmary {
  id              String           @id @default(cuid())
  tenantId        String
  name            String
  status          InfirmaryStatus  @default(ACTIVE)
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cases           InfirmaryCase[]
  quarantineCases QuarantineCase[]
}

model InfirmaryCase {
  id                   String               @id @default(cuid())
  tenantId             String
  birdId               String
  infirmaryId          String
  openedAt             DateTime
  protocolStartedAt    DateTime?
  protocolDurationDays Int                  @default(5)
  diagnosis            String?
  symptoms             String?
  medication           String?
  dosage               String?
  responsible          String?
  status               InfirmaryCaseStatus  @default(TREATING)
  notes                String?
  closedAt             DateTime?
  diseaseId            String?
  medicationId         String?
  deathReasonId        String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  tenant        Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bird          Bird                     @relation(fields: [birdId], references: [id], onDelete: Restrict)
  infirmary     Infirmary                @relation(fields: [infirmaryId], references: [id], onDelete: Restrict)
  disease       Disease?                 @relation(fields: [diseaseId], references: [id], onDelete: SetNull)
  medicationRef Medication?              @relation(fields: [medicationId], references: [id], onDelete: SetNull)
  deathReason   DeathReason?             @relation(fields: [deathReasonId], references: [id], onDelete: SetNull)
  events        InfirmaryCaseEvent[]
  treatments    InfirmaryCaseTreatment[]
}

model InfirmaryCaseEvent {
  id              String        @id @default(cuid())
  tenantId        String
  caseId          String
  type            String
  notes           String?
  fromInfirmaryId String?
  toInfirmaryId   String?
  createdAt       DateTime      @default(now())
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  case            InfirmaryCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
}

model QuarantineChecklistTemplate {
  id                      String                   @id @default(cuid())
  tenantId                String
  name                    String
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  tenant                  Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  treatments              QuarantineTreatment[]
  infirmaryCaseTreatments InfirmaryCaseTreatment[]

  @@unique([tenantId, name])
}

// Itens de checklist (vacinas/medicamentos/protocolos) aplicados num caso
// clinico especifico. Reaproveita os mesmos QuarantineChecklistTemplate
// (sao "itens reutilizaveis" do sitio, independente do contexto).
model InfirmaryCaseTreatment {
  id              String                       @id @default(cuid())
  tenantId        String
  infirmaryCaseId String
  templateId      String?
  label           String
  startDate       DateTime
  notes           String?
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt
  tenant          Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  infirmaryCase   InfirmaryCase                @relation(fields: [infirmaryCaseId], references: [id], onDelete: Cascade)
  template        QuarantineChecklistTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
}

model QuarantineCase {
  id               String                @id @default(cuid())
  tenantId         String
  birdId           String
  infirmaryId      String
  entryDate        DateTime
  expectedExitDate DateTime
  notes            String?
  status           QuarantineCaseStatus  @default(ACTIVE)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  tenant           Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bird             Bird                  @relation(fields: [birdId], references: [id], onDelete: Restrict)
  infirmary        Infirmary             @relation(fields: [infirmaryId], references: [id], onDelete: Restrict)
  treatments       QuarantineTreatment[]
}

model QuarantineTreatment {
  id               String                       @id @default(cuid())
  tenantId         String
  quarantineCaseId String
  templateId       String?
  label            String
  startDate        DateTime
  notes            String?
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt
  tenant           Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  quarantineCase   QuarantineCase               @relation(fields: [quarantineCaseId], references: [id], onDelete: Cascade)
  template         QuarantineChecklistTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
}

model FinancialEntry {
  id            String         @id @default(cuid())
  tenantId      String
  date          DateTime
  category      String
  item          String
  amount        Decimal        @db.Decimal(12, 2)
  description   String?
  customer      String?
  notes         String?
  paymentMethod PaymentMethod?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  eggSale       EggSale?
  vitrineSales  VitrineSale[]
  // Lead que originou essa venda (CRM Kanban). SetNull no schema do
  // Lead garante que apagar a entry nao quebre — o cancelamento manual
  // em deleteEntry() reverte explicitamente o card pra EM_NEGOCIACAO.
  lead          Lead?
}

model EggTray {
  id           String         @id @default(cuid())
  tenantId     String
  flockGroupId String?
  speciesLabel String
  breedLabel   String
  varietyLabel String?
  expiryDays   Int            @default(10)
  status       EggTrayStatus  @default(ACTIVE)
  notes        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  flockGroup   FlockGroup?    @relation(fields: [flockGroupId], references: [id], onDelete: SetNull)
  entries      EggTrayEntry[]

  @@index([tenantId, status])
}

model EggTrayEntry {
  id               String         @id @default(cuid())
  tenantId         String
  trayId           String
  eggCollectionId  String?        @unique
  source           EggTraySource  @default(COLLECTION)
  entryDate        DateTime
  initialCount     Int
  soldCount        Int            @default(0)
  discardedCount   Int            @default(0)
  transferredCount Int            @default(0)
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tray             EggTray        @relation(fields: [trayId], references: [id], onDelete: Cascade)
  eggCollection    EggCollection? @relation(fields: [eggCollectionId], references: [id], onDelete: SetNull)
  saleItems        EggSaleItem[]

  @@index([tenantId, trayId, entryDate])
}

model EggSale {
  id               String          @id @default(cuid())
  tenantId         String
  customer         String?
  totalAmount      Decimal         @db.Decimal(12, 2)
  soldAt           DateTime
  paymentMethod    PaymentMethod?
  shippingFee      Decimal?        @db.Decimal(10, 2)
  financialEntryId String?         @unique
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  tenant           Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  financialEntry   FinancialEntry? @relation(fields: [financialEntryId], references: [id], onDelete: SetNull)
  items            EggSaleItem[]

  @@index([tenantId, soldAt])
}

model EggSaleItem {
  id          String       @id @default(cuid())
  tenantId    String
  saleId      String
  trayEntryId String
  quantity    Int
  unitPrice   Decimal      @db.Decimal(10, 2)
  subtotal    Decimal      @db.Decimal(12, 2)
  createdAt   DateTime     @default(now())
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sale        EggSale      @relation(fields: [saleId], references: [id], onDelete: Cascade)
  trayEntry   EggTrayEntry @relation(fields: [trayEntryId], references: [id], onDelete: Restrict)
}

model FinancialExpense {
  id          String   @id @default(cuid())
  tenantId    String
  date        DateTime
  category    String
  item        String
  amount      Decimal  @db.Decimal(12, 2)
  description String?
  supplier    String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Report {
  id          String     @id @default(cuid())
  tenantId    String
  generatedBy String
  type        ReportType
  periodStart DateTime
  periodEnd   DateTime
  fileUrl     String?
  metadata    Json?
  createdAt   DateTime   @default(now())
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User       @relation(fields: [generatedBy], references: [id], onDelete: Restrict)
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String?
  action    String
  entity    String
  entityId  String
  before    Json?
  after     Json?
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model WorkerAccessLink {
  id              String   @id @default(cuid())
  tenantId        String
  label           String
  token           String   @unique
  isActive        Boolean  @default(true)
  allowPlantel    Boolean  @default(true)
  allowEggs       Boolean  @default(true)
  allowIncubators Boolean  @default(true)
  allowHealth     Boolean  @default(true)
  allowDashboard  Boolean  @default(true)
  allowPrateleira Boolean  @default(true)
  allowVitrine    Boolean  @default(true)
  allowFinanceiro Boolean  @default(true)
  allowRelatorios Boolean  @default(true)
  allowCrm        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model EmployeeAccount {
  id              String            @id @default(cuid())
  tenantId        String
  name            String
  email           String
  passwordHash    String
  isActive        Boolean           @default(true)
  allowPlantel    Boolean           @default(true)
  allowEggs       Boolean           @default(true)
  allowIncubators Boolean           @default(true)
  allowHealth     Boolean           @default(true)
  allowDashboard  Boolean           @default(true)
  allowPrateleira Boolean           @default(true)
  allowVitrine    Boolean           @default(true)
  allowFinanceiro Boolean           @default(true)
  allowRelatorios Boolean           @default(true)
  allowCrm        Boolean           @default(false)
  lastLoginAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions        EmployeeSession[]

  @@unique([tenantId, email])
}

model EmployeeSession {
  id         String          @id @default(cuid())
  tenantId   String
  employeeId String
  token      String          @unique
  expiresAt  DateTime
  createdAt  DateTime        @default(now())
  tenant     Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee   EmployeeAccount @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model PriceTier {
  id           String   @id @default(cuid())
  tenantId     String
  flockGroupId String
  ageInMonths  Int
  price        Decimal  @db.Decimal(10, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  flockGroup FlockGroup @relation(fields: [flockGroupId], references: [id], onDelete: Cascade)

  @@unique([tenantId, flockGroupId, ageInMonths])
  @@index([tenantId, flockGroupId])
}

model VitrineListing {
  id                String        @id @default(cuid())
  tenantId          String
  flockGroupId      String
  title             String?
  birthDate         DateTime
  initialQuantity   Int
  availableQuantity Int
  priceOverride     Decimal?      @db.Decimal(10, 2)
  description       String?
  status            ListingStatus @default(AVAILABLE)

  sourceIncubatorBatchId String?
  sourceBirdId           String? @unique

  publishedToOrnamarketAt DateTime?
  ornamarketListingId     String?
  ornamarketListingUrl    String?

  purchaseDate DateTime?
  purchaseCost Decimal?  @db.Decimal(10, 2)
  vendorName   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  flockGroup FlockGroup @relation(fields: [flockGroupId], references: [id], onDelete: Restrict)

  sourceIncubatorBatch IncubatorBatch? @relation(fields: [sourceIncubatorBatchId], references: [id], onDelete: SetNull)
  sourceBird           Bird?           @relation(fields: [sourceBirdId], references: [id], onDelete: SetNull)

  photos VitrineListingPhoto[]
  sales  VitrineSale[]
  deaths VitrineDeathRecord[]

  @@index([tenantId, status])
  @@index([tenantId, flockGroupId])
}

model VitrineListingPhoto {
  id        String   @id @default(cuid())
  listingId String
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  listing VitrineListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, order])
}

model VitrineSale {
  id               String        @id @default(cuid())
  tenantId         String
  listingId        String
  quantitySold     Int
  unitPrice        Decimal       @db.Decimal(10, 2)
  totalPrice       Decimal       @db.Decimal(10, 2)
  paymentMethod    PaymentMethod
  customer         String?
  notes            String?
  soldAt           DateTime      @default(now())
  // Antes era @unique (1:1 com FinancialEntry). Removido pra permitir
  // 1 venda agregada (FinancialEntry unico) com varias VitrineSale —
  // mesmo padrao do EggSale com items, suporta o carrinho da Vitrine.
  financialEntryId String?

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  listing        VitrineListing  @relation(fields: [listingId], references: [id], onDelete: Restrict)
  financialEntry FinancialEntry? @relation(fields: [financialEntryId], references: [id], onDelete: SetNull)

  @@index([tenantId, listingId])
  @@index([tenantId, soldAt])
  @@index([financialEntryId])
}

model VitrineDeathRecord {
  id            String   @id @default(cuid())
  tenantId      String
  listingId     String
  quantity      Int
  cause         String?
  deathReasonId String?
  occurredAt    DateTime @default(now())

  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  listing     VitrineListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  deathReason DeathReason?   @relation(fields: [deathReasonId], references: [id], onDelete: SetNull)

  @@index([tenantId, listingId])
  @@index([tenantId, occurredAt])
}

model Disease {
  id               String   @id @default(cuid())
  tenantId         String
  name             String
  description      String?
  symptoms         String?
  defaultTreatment String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cases  InfirmaryCase[]

  @@unique([tenantId, name])
}

model Medication {
  id            String   @id @default(cuid())
  tenantId      String
  name          String
  defaultDosage String?
  route         String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cases  InfirmaryCase[]

  @@unique([tenantId, name])
}

model Vaccine {
  id                   String   @id @default(cuid())
  tenantId             String
  name                 String
  recommendedAgeMonths Int?
  recommendedAgeUnit   String?  @default("months")
  intervalMonths       Int?
  intervalUnit         String?  @default("months")
  notes                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vaccinations BirdVaccination[]

  @@unique([tenantId, name])
}

model DeathReason {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant        Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cases         InfirmaryCase[]
  vitrineDeaths VitrineDeathRecord[]

  @@unique([tenantId, name])
}

model BirdVaccination {
  id        String   @id @default(cuid())
  tenantId  String
  birdId    String
  vaccineId String
  appliedAt DateTime
  notes     String?
  createdAt DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bird    Bird    @relation(fields: [birdId], references: [id], onDelete: Cascade)
  vaccine Vaccine @relation(fields: [vaccineId], references: [id], onDelete: Restrict)

  @@index([tenantId, birdId])
  @@index([tenantId, vaccineId])
  @@index([tenantId, appliedAt])
}

// === CRM Kanban ===

enum LeadStage {
  NOVO_CONTATO
  EM_NEGOCIACAO
  COMPROU
  DESISTIU
}

enum LeadChannel {
  WHATSAPP
  OLX
  INSTAGRAM
  TIKTOK
  ORNAMARKET
  SITE
  ADS_OFFLINE
  INDICACAO
  OUTRO
}

enum LeadInterestType {
  AVES
  OVOS
  MAMIFEROS
  OUTROS
}

// 1 Lead = 1 card no Kanban CRM. lastInteractionAt zera em cada
// movimento/edit pra alimentar a barra de temperatura calculada no
// client. archivedAt null = ativo no Kanban.
// Sub-status livre (string) com lista controlada no client por stage.
model Lead {
  id                String            @id @default(cuid())
  tenantId          String
  // identidade
  name              String
  phone             String?
  email             String?
  city              String?
  state             String?
  avatarUrl         String?
  // negocio
  stage             LeadStage         @default(NOVO_CONTATO)
  subStatus         String?
  channel           LeadChannel
  channelOther      String?
  interestType      LeadInterestType?
  interestText      String?
  observation       String?
  tags              String[]          @default([])
  // controle de tempo / arquivamento
  lastInteractionAt DateTime          @default(now())
  archivedAt        DateTime?
  archivedReason    String?
  // posicao Kanban (Float estilo Trello)
  position          Float             @default(0)
  // venda concluida
  financialEntryId  String?           @unique
  // timestamps
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  financialEntry    FinancialEntry?   @relation(fields: [financialEntryId], references: [id], onDelete: SetNull)
  history           LeadHistory[]

  @@index([tenantId, stage, archivedAt])
  @@index([tenantId, archivedAt])
  @@index([tenantId, phone])
}

// Timeline do lead (movimentacoes + edits + observacoes)
model LeadHistory {
  id          String   @id @default(cuid())
  tenantId    String
  leadId      String
  type        String   // STAGE_CHANGE | SUBSTATUS_CHANGE | NOTE | ARCHIVED | RESTORED | SALE_RECORDED | SALE_CANCELED
  fromValue   String?
  toValue     String?
  notes       String?
  actorUserId String?
  createdAt   DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
}
