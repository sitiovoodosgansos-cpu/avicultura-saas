generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
  SUPER_ADMIN
}

enum TenantStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELED
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum BirdSex {
  FEMALE
  MALE
  UNKNOWN
}

enum BirdStatus {
  ACTIVE
  SICK
  DEAD
  BROODY
}

enum IncubatorStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum BatchStatus {
  ACTIVE
  HATCHED
  FAILED
  CANCELED
}

enum InfirmaryStatus {
  ACTIVE
  INACTIVE
}

enum InfirmaryCaseStatus {
  TREATING
  CURED
  DEAD
  TRANSFERRED
}

enum ReportType {
  GENERAL
  FLOCK
  EGG
  INCUBATOR
  HEALTH
  FINANCIAL
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  name         String
  role         UserRole       @default(MEMBER)
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  memberships  TenantMember[]
  auditLogs    AuditLog[]
  reports      Report[]
}

model Tenant {
  id             String          @id @default(cuid())
  name           String
  slug           String          @unique
  status         TenantStatus    @default(TRIAL)
  trialStartsAt  DateTime        @default(now())
  trialEndsAt    DateTime
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  members        TenantMember[]
  farms          Farm[]
  subscriptions  Subscription[]
  paymentEvents  PaymentEvent[]
  species        Species[]
  breeds         Breed[]
  varieties      Variety[]
  flockGroups    FlockGroup[]
  birds          Bird[]
  birdHistories  BirdStatusHistory[]
  eggCollections EggCollection[]
  incubators     Incubator[]
  batches        IncubatorBatch[]
  batchEvents    IncubatorBatchEvent[]
  infirmaries    Infirmary[]
  infirmaryCases InfirmaryCase[]
  infirmaryCaseEvents InfirmaryCaseEvent[]
  entries        FinancialEntry[]
  expenses       FinancialExpense[]
  reports        Report[]
  auditLogs      AuditLog[]
}

model TenantMember {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  role      UserRole @default(OWNER)
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
}

model Farm {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  location  String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                 String             @id @default(cuid())
  tenantId           String
  provider           String             @default("stripe")
  providerCustomerId String?
  providerSubId      String?
  status             SubscriptionStatus @default(TRIALING)
  planCode           String             @default("starter")
  trialEndsAt        DateTime?
  currentPeriodEnd   DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  tenant             Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model PaymentEvent {
  id              String   @id @default(cuid())
  tenantId        String
  providerEventId String   @unique
  type            String
  payload         Json
  processedAt     DateTime?
  createdAt       DateTime @default(now())
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Species {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  breeds    Breed[]
  groups    FlockGroup[]
}

model Breed {
  id        String   @id @default(cuid())
  tenantId  String
  speciesId String
  name      String
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  species   Species  @relation(fields: [speciesId], references: [id], onDelete: Cascade)
  varieties Variety[]
  groups    FlockGroup[]
}

model Variety {
  id        String   @id @default(cuid())
  tenantId  String
  breedId   String
  name      String
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  breed     Breed    @relation(fields: [breedId], references: [id], onDelete: Cascade)
  groups    FlockGroup[]
}

model FlockGroup {
  id                      String          @id @default(cuid())
  tenantId                String
  speciesId               String
  breedId                 String
  varietyId               String?
  title                   String
  matrixCount             Int             @default(0)
  reproducerCount         Int             @default(0)
  expectedLayCapacity     Float?
  purchaseInvestmentTotal Decimal?        @db.Decimal(12, 2)
  purchaseDate            DateTime?
  notes                   String?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  tenant                  Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  species                 Species         @relation(fields: [speciesId], references: [id], onDelete: Restrict)
  breed                   Breed           @relation(fields: [breedId], references: [id], onDelete: Restrict)
  variety                 Variety?        @relation(fields: [varietyId], references: [id], onDelete: SetNull)
  birds                   Bird[]
  eggCollections          EggCollection[]
  batches                 IncubatorBatch[]
}

model Bird {
  id              String              @id @default(cuid())
  tenantId        String
  flockGroupId    String
  ringNumber      String
  nickname        String?
  sex             BirdSex             @default(UNKNOWN)
  acquisitionDate DateTime?
  purchaseValue   Decimal?            @db.Decimal(12, 2)
  origin          String?
  status          BirdStatus          @default(ACTIVE)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  flockGroup      FlockGroup          @relation(fields: [flockGroupId], references: [id], onDelete: Cascade)
  statusHistory   BirdStatusHistory[]
  infirmaryCases  InfirmaryCase[]

  @@unique([tenantId, ringNumber])
}

model BirdStatusHistory {
  id         String     @id @default(cuid())
  tenantId   String
  birdId     String
  fromStatus BirdStatus?
  toStatus   BirdStatus
  reason     String?
  createdAt  DateTime   @default(now())
  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bird       Bird       @relation(fields: [birdId], references: [id], onDelete: Cascade)
}

model EggCollection {
  id          String   @id @default(cuid())
  tenantId    String
  flockGroupId String
  date        DateTime
  totalEggs   Int
  goodEggs    Int
  crackedEggs Int
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  flockGroup  FlockGroup @relation(fields: [flockGroupId], references: [id], onDelete: Cascade)
}

model Incubator {
  id        String         @id @default(cuid())
  tenantId  String
  name      String
  description String?
  status    IncubatorStatus @default(ACTIVE)
  notes     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  batches   IncubatorBatch[]
}

model IncubatorBatch {
  id                String      @id @default(cuid())
  tenantId          String
  incubatorId       String
  flockGroupId      String
  entryDate         DateTime
  eggsSet           Int
  expectedHatchDate DateTime?
  status            BatchStatus @default(ACTIVE)
  notes             String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  tenant            Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  incubator         Incubator   @relation(fields: [incubatorId], references: [id], onDelete: Cascade)
  flockGroup        FlockGroup  @relation(fields: [flockGroupId], references: [id], onDelete: Restrict)
  events            IncubatorBatchEvent[]
}

model IncubatorBatchEvent {
  id        String   @id @default(cuid())
  tenantId  String
  batchId   String
  type      String
  quantity  Int      @default(0)
  eventDate DateTime
  notes     String?
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  batch     IncubatorBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
}

model Infirmary {
  id        String          @id @default(cuid())
  tenantId  String
  name      String
  status    InfirmaryStatus @default(ACTIVE)
  notes     String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cases     InfirmaryCase[]
}

model InfirmaryCase {
  id          String             @id @default(cuid())
  tenantId    String
  birdId      String
  infirmaryId String
  openedAt    DateTime
  diagnosis   String?
  symptoms    String?
  medication  String?
  dosage      String?
  responsible String?
  status      InfirmaryCaseStatus @default(TREATING)
  notes       String?
  closedAt    DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bird        Bird               @relation(fields: [birdId], references: [id], onDelete: Restrict)
  infirmary   Infirmary          @relation(fields: [infirmaryId], references: [id], onDelete: Restrict)
  events      InfirmaryCaseEvent[]
}

model InfirmaryCaseEvent {
  id              String   @id @default(cuid())
  tenantId        String
  caseId          String
  type            String
  notes           String?
  fromInfirmaryId String?
  toInfirmaryId   String?
  createdAt       DateTime @default(now())
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  case            InfirmaryCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
}

model FinancialEntry {
  id          String            @id @default(cuid())
  tenantId    String
  date        DateTime
  category    String
  item        String
  amount      Decimal           @db.Decimal(12, 2)
  description String?
  customer    String?
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model FinancialExpense {
  id          String            @id @default(cuid())
  tenantId    String
  date        DateTime
  category    String
  item        String
  amount      Decimal           @db.Decimal(12, 2)
  description String?
  supplier    String?
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Report {
  id          String    @id @default(cuid())
  tenantId    String
  generatedBy String
  type        ReportType
  periodStart DateTime
  periodEnd   DateTime
  fileUrl     String?
  metadata    Json?
  createdAt   DateTime  @default(now())
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [generatedBy], references: [id], onDelete: Restrict)
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String?
  action    String
  entity    String
  entityId  String
  before    Json?
  after     Json?
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}
