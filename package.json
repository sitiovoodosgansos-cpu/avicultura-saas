    "release:check-env": "node scripts/check-release-env.mjs",
    "mobile:android:add": "npx cap add android",
    "mobile:android:sync": "node scripts/mobile-sync-android.mjs prod",
    "mobile:android:sync:preview": "node scripts/mobile-sync-android.mjs preview",
    "mobile:android:sync:custom": "node scripts/mobile-sync-android.mjs custom",
    "mobile:android:open": "npx cap open android"
